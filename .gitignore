# ── User data (real user folders — keep only the _template) ──────────────────
brain/USERS/*/
!brain/USERS/_template/
!brain/USERS/_template/**

# ── Personal session memory (generated per deployment) ────────────────────────
brain/Memory/Daily Notes/

# ── Runtime hosting config (contains tunnel token — generated per deployment) ─
brain/hosting.json

# ── AI provider settings (contains API keys — written by Admin UI) ────────────
brain/ai_settings.json

# ── Auth registry (contains hashed passwords — lives in brain/_system/ at runtime)
brain/_system/

# ── Auth registry (root placement used in local dev — contains hashed passwords)
auth.json

# ── Environment / secrets ─────────────────────────────────────────────────────
docker/.env
.env
*.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.pytest_cache/

# ── Node / frontend ───────────────────────────────────────────────────────────
app/frontend/node_modules/
app/frontend/dist/

# ── Docker volume data ────────────────────────────────────────────────────────
docker/ntfy_data/
docker/postgres_data/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
backups/

# Claude Code personal overrides (never commit)
.claude/settings.local.json
