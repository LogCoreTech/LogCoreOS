# LogCore OS — Environment Variables
# Copy this file to .env and fill in your values

# Path to the Brain directory (default inside Docker — rarely needs changing)
# BRAIN_PATH=/data/brain

# Required: generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# AI provider (only "anthropic" is supported today; more providers coming in Phase 6)
AI_PROVIDER=anthropic

# Required for AI chat when using the Anthropic provider
ANTHROPIC_API_KEY=

# AI model to use (default: claude-sonnet-4-6)
AI_MODEL=claude-sonnet-4-6

# CORS origins. Leave EMPTY (the secure default) for a normal bundled deployment —
# the UI is served from the same origin as the API, so no cross-origin access is
# needed. Only set this if a SEPARATE front-end origin must call the API:
#   ALLOWED_ORIGINS=https://logcore.yourdomain.com,http://192.168.1.100:8000
# Setting it to "*" reflects ANY origin with credentials — only do that on a trusted
# LAN, never on an internet-exposed instance.
ALLOWED_ORIGINS=

# Auth cookie Secure flag. Keep true whenever the app is reached over HTTPS
# (Cloudflare Tunnel, reverse proxy, etc.). Set to false ONLY for local plain-HTTP
# development — on HTTP a true value stops the browser from ever sending the cookie.
COOKIE_SECURE=true

# Scheduler timezone — must be a valid IANA timezone string
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULER_TIMEZONE=America/Chicago

# Scheduled job times (24-hour, in SCHEDULER_TIMEZONE)
MORNING_DIGEST_HOUR=6
OVERDUE_CHECK_HOUR=19

# Set to true only to allow anyone to self-register (dev/testing).
# Default (false): only the first user can self-register (they become admin).
# After that, admins add new users by calling /api/auth/register with their token.
ALLOW_OPEN_REGISTRATION=false

# Set to true when the app runs behind a trusted reverse proxy (nginx, Caddy, Traefik).
# Enables the rate limiter to read the real client IP from the X-Forwarded-For header.
# Leave false when the app is exposed directly to the internet.
TRUST_PROXY_HEADERS=false

# Require a valid GPG signature on incoming updates. When true, docker/update.sh
# refuses to build any pulled commit that isn't GPG-signed (on the commit or an
# annotated tag pointing at it) by a key trusted in the updater's keyring —
# hardening the auto-updater against a compromised origin or MITM. Default false so
# unsigned deployments keep updating. Before enabling: GPG-sign your release
# commits/tags and `gpg --import` the signing public key into the updater's keyring.
# UPDATE_REQUIRE_SIGNATURE=false

# Web Search for AI Research mode — Tavily (https://tavily.com, free tier: 1 000 searches/month)
# Can also be set via Admin → Web Search in the UI.
# TAVILY_API_KEY=tvly-…

# ── ntfy publisher auth ───────────────────────────────────────────────────────
# ntfy has no auth by default (open publish, ID-gated read — fine on a LAN-only
# instance). launch.sh auto-provisions these once, the first time it can reach
# ntfy: an admin "publisher" account + token for the app, and flips
# NTFY_AUTH_DEFAULT_ACCESS to read-only so publishing needs the token while
# anonymous subscribe keeps working. Matters once ntfy has a public hostname
# (e.g. mapped through the Cloudflare tunnel). Leave both unset — launch.sh
# manages them; only hand-edit if you're hardening an existing install manually.
# NTFY_PUBLISH_TOKEN=
# NTFY_AUTH_DEFAULT_ACCESS=read-only

# ── n8n Workflow Automation ───────────────────────────────────────────────────
# Bundled n8n runs at http://n8n:5678 by default. Override via Admin → n8n.
# Required: generate a strong random key for N8N_ENCRYPTION_KEY.
# N8N_API_KEY=logcore-n8n-key
# N8N_ENCRYPTION_KEY=change-me-n8n

# ── Managed Hosting (LogCore-run instances only) ──────────────────────────────
# Leave all of these blank for self-hosted deployments — they are never needed.
# When INFISICAL_TOKEN is set, secrets (SECRET_KEY, ANTHROPIC_API_KEY, etc.)
# are pulled from the Infisical server at startup instead of from this file.
# INFISICAL_URL=https://your-infisical-server.com
# INFISICAL_TOKEN=
# INFISICAL_ENV=prod
# INFISICAL_PROJECT_ID=   # optional — only needed if your Infisical setup requires it
